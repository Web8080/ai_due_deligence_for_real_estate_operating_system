# Author: Victor.I
# Copy to .env.local (Next.js loads it automatically).

# Where Next.js proxies /api/reos/* (server-side). Default matches local uvicorn.
# REOS_API_PROXY_TARGET=http://127.0.0.1:8000

# Optional: call the API directly from the browser (same host/port as this file or CORS must allow your origin).
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
