# Author: Victor.I
# Copy to .env and set values. Required for local recovery login (e.g. admin/admin123).

# Enable creation of default users (admin, analyst1, manager1) and allow local login.
REOS_ENABLE_LOCAL_BOOTSTRAP=true
REOS_LOCAL_LOGIN_ENABLED=true

# Fixed secret so sessions survive server restarts. Set a strong value in production.
REOS_SESSION_SECRET=your-secret-at-least-32-chars

# Local sandbox: self-serve analyst signup (requires REOS_LOCAL_LOGIN_ENABLED=true). Off in production.
# REOS_ALLOW_LOCAL_SIGNUP=true

# UI/API posture: mark integration catalog as demo-only (no vendor traffic implied). Safe for stakeholder demos.
# REOS_PRODUCT_DEMO_MODE=true

# Optional: prospecting / enrichment (integration catalog toggles; wire workers before production use).
# REOS_APOLLO_API_KEY=
# REOS_SNOV_API_KEY=
# Macro rates (FRED) for underwriting overlays and dashboards.
# REOS_FRED_API_KEY=
# Enterprise market-data posture label for Bloomberg / Refinitiv / ICE adapters (placeholder until contracted).
# REOS_INSTITUTIONAL_MARKET_DATA_MODE=unconfigured

# Optional: Microsoft Entra (tenant, client, secret, redirect, frontend callback).
# REOS_ENTRA_TENANT_ID=
# REOS_ENTRA_CLIENT_ID=
# REOS_ENTRA_CLIENT_SECRET=
# REOS_ENTRA_REDIRECT_URI=
# REOS_ENTRA_FRONTEND_CALLBACK=http://localhost:30001/auth/microsoft/callback
